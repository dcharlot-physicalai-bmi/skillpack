{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skillpack.dev/schema/registry.schema.json",
  "title": "skillpack registry index",
  "type": "object",
  "required": ["name", "version", "skills"],
  "properties": {
    "name": { "type": "string" },
    "version": { "type": "string" },
    "homepage": { "type": "string" },
    "description": { "type": "string" },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path", "files", "policy", "requires"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "title": { "type": "string" },
          "version": { "type": "string" },
          "path": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "runtime": { "type": "string" },
          "policy": { "enum": ["analytic", "vla", "lerobot", "mlp"] },
          "checkpoint": { "type": "string" },
          "requires": { "type": "object" },
          "summary": { "type": "string" }
        }
      }
    },
    "robots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "label": { "type": "string" }
        }
      }
    }
  }
}
